# Copy to ~/.cloudflared/config.yml on the EC2 box after running:
#   cloudflared tunnel create kite-api-prod
#   cloudflared tunnel route dns kite-api-prod api.ayushgupta.us
# Then replace <TUNNEL_ID> below with the id printed by `tunnel create`
# (also visible in the generated credentials filename).
tunnel: kite-api-prod
credentials-file: /home/ubuntu/.cloudflared/<TUNNEL_ID>.json
ingress:
  - hostname: api.ayushgupta.us
    service: http://localhost:8000
  - service: http_status:404
